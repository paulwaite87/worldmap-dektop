#!/usr/bin/env python3

import os
import re
import sys
import argparse
import configparser
from pathlib import Path
from cloudmap.create_map import main

SCRIPT_SECTION = "clouds"

if __name__ == '__main__':
    parser = argparse.ArgumentParser(description="Create Cloud Map")
    parser.add_argument("--config", required=True, help="Path to main config")
    args = parser.parse_args()

    if not os.path.exists(args.config):
        raise FileNotFoundError(f"Config file not found at {args.config}")

    config = configparser.ConfigParser()
    config.read(args.config)
    s = SCRIPT_SECTION
    if not config.getboolean(s, 'enabled', fallback=False):
        sys.exit(0)

    try:
        # Extract values from main config
        workdir = config.get('common', 'workdir')
        outfile = config.get(s, 'outfile')
        width = config.getint(s, 'width')
        height = config.getint(s, 'height')

        # Derive paths for the temporary cloud_map.conf
        # If outfile is 'data/cloud_map.jpg', p.parent is 'data' and p.name is 'cloud_map.jpg'
        p = Path(outfile)
        dest_dir = str(p.parent)
        dest_file = p.name

        # Path where the generated config will live
        temp_conf_path = os.path.join(workdir, "data", "cloud_map.conf")

        # Generate the on-the-fly config file
        temp_config = configparser.ConfigParser()
        temp_config['xplanet'] = {
            'destinationdir': dest_dir,
            'destinationfile': dest_file,
            'width': str(width),
            'height': str(height)
        }

        with open(temp_conf_path, 'w') as f:
            temp_config.write(f)

        print(f"Generated temporary config: {temp_conf_path}")

        # Prepare for the cloudmap.create_map.main() call
        # We must strip out OUR arguments (--config) and replace them
        # with what the library expects: --conf_file
        sys.argv = [
            re.sub(r'(-script\.pyw|\.exe)?$', '', sys.argv[0]),
            f"--conf_file={temp_conf_path}"
        ]

        # Hand over control to CreateCloudMap.cloudmap.create_map
        sys.exit(main())

    except Exception as e:
        print(f"Error during cloud map generation: {e}")
        sys.exit(1)