#!/usr/bin/env python3
import os
import sys
import logging
import argparse
import subprocess
import configparser

# Setup logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[logging.StreamHandler(sys.stdout)]
)
logger = logging.getLogger(__name__)


def main():
    parser = argparse.ArgumentParser(description="Composite Isobars onto Cloud Map")
    parser.add_argument("--config", required=True, help="Path to main config file")
    args = parser.parse_args()

    if not os.path.exists(args.config):
        logger.error(f"Config not found: {args.config}")
        sys.exit(1)

    # 1. Load Configuration
    config = configparser.ConfigParser()
    config.read(args.config)

    try:
        # 2. Extract paths from config
        # Background (Clouds)
        cloud_map = config.get('clouds', 'outfile')

        # Overlay (Isobars)
        isobar_map = config.get('isobars', 'outfile')

        # Destination for composite image
        output_map = config.get('isobars', 'composite_outfile',
                                fallback='data/cloud_map_with_isobars.jpg')

        # Verify source files exist before attempting composite
        for f in [cloud_map, isobar_map]:
            if not os.path.exists(f):
                logger.error(f"Source file missing: {f}")
                sys.exit(1)

        # Construct the ImageMagick command
        # Syntax: composite <overlay> <background> <output>
        cmd = ["composite", isobar_map, cloud_map, output_map]

        logger.info(f"Composite isobars + clouds --> {output_map}")

        # Create composite image
        subprocess.run(cmd, check=True)
        logger.info(f"Successfully created: {output_map}")

    except (configparser.NoSectionError, configparser.NoOptionError) as e:
        logger.critical(f"Config error: {e}")
        sys.exit(1)
    except subprocess.CalledProcessError as e:
        logger.error(f"ImageMagick composite failed: {e}")
        sys.exit(1)
    except Exception as e:
        logger.error(f"Unexpected error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()