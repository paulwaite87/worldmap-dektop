#!/home/pj/venv/bin/python3

import asyncio
import websockets
import json
import os
import sys
import configparser
import argparse
from websockets.exceptions import ConnectionClosed

SCRIPT_SECTION = 'shipping_harvester'

def load_cache(cache_path):
    if os.path.exists(cache_path):
        if os.path.getsize(cache_path) == 0:
            return {}
        with open(cache_path, 'r') as f:
            try: return json.load(f)
            except json.JSONDecodeError:
                bak = cache_path + ".broken"
                print(f"Corrupted cache. Moving to {bak}")
                try: os.rename(cache_path, bak)
                except: pass
                return {}
    return {}

def save_cache(cache_path, cache_data):
    os.makedirs(os.path.dirname(cache_path), exist_ok=True)
    with open(cache_path, 'w') as f:
        json.dump(cache_data, f, indent=4)

async def get_static_chunk(url, api_key, duration, bbox_chunk):
    messages = []
    sub = {"APIKey": api_key, "BoundingBoxes": [bbox_chunk], "FilterMessageTypes": ["ShipStaticData"]}
    try:
        async with websockets.connect(url, close_timeout=1) as ws:
            await ws.send(json.dumps(sub))
            start = asyncio.get_event_loop().time()
            while asyncio.get_event_loop().time() - start < duration:
                try:
                    msg = await asyncio.wait_for(ws.recv(), timeout=1.0)
                    messages.append(json.loads(msg))
                except asyncio.TimeoutError: continue
                except ConnectionClosed: break
    except Exception as e: print(f"  Chunk Error: {e}")
    return messages

async def run_chunked_harvest(**kwargs):
    url = kwargs.get('url')
    api_key = kwargs.get('api_key')
    duration = kwargs.get('duration', 60)
    full_bbox = kwargs.get('full_bbox')
    chunks = kwargs.get('chunks', 1)
    workdir = kwargs.get('workdir')
    db_rel_path = kwargs.get('db_rel_path')

    full_db_path = os.path.join(workdir, db_rel_path)
    ship_cache = load_cache(full_db_path)
    print(f"Starting Harvest: {chunks} chunks on {full_db_path}")

    (lat_s, lon_w), (lat_n, lon_e) = full_bbox[0]
    chunk_width = (lon_e - lon_w) / chunks

    for i in range(chunks):
        c_lon_w = lon_w + (i * chunk_width)
        c_lon_e = c_lon_w + chunk_width
        current_chunk = [[lat_s, c_lon_w], [lat_n, c_lon_e]]
        print(f"  -> Chunk {i+1}/{chunks} (Lon {c_lon_w:.1f} to {c_lon_e:.1f})...")
        
        raw_data = await get_static_chunk(url, api_key, duration, current_chunk)
        updates = 0
        
        for msg in raw_data:
            if msg.get("MessageType") == "ShipStaticData":
                meta = msg.get("MetaData", {})
                body = msg.get("Message", {}).get("ShipStaticData", {})
                mmsi = str(meta.get("MMSI") or body.get("UserID", ""))
                if not mmsi: continue

                new_drgt = body.get("MaximumStaticDraught", 0.0)
                
                if mmsi not in ship_cache:
                    ship_cache[mmsi] = {
                        'name': (meta.get("ShipName") or body.get("Name") or "Unknown").strip(),
                        'type': body.get("Type") or body.get("VesselType") or 0,
                        'imo': body.get("ImoNumber", 0),
                        'callsign': body.get("CallSign", "").strip(),
                        'dimensions': body.get("Dimension", {}),
                        'draught': new_drgt, 'prev_draught': 0.0
                    }
                    updates += 1
                else:
                    curr = ship_cache[mmsi]
                    changed = False
                    
                    if new_drgt != 0.0 and curr.get('draught', 0.0) != 0.0 and curr['draught'] != new_drgt:
                        curr['prev_draught'] = curr['draught']
                        curr['draught'] = new_drgt
                        changed = True
                        print(f"     [DRAUGHT CHANGE] {curr['name']}: {curr['prev_draught']}m -> {new_drgt}m")

                    if curr.get('type') == 0 and body.get("Type", 0) != 0:
                        curr['type'] = body.get("Type"); changed = True
                    if (not curr.get('imo') or curr['imo'] == 0) and body.get("ImoNumber", 0) != 0:
                        curr['imo'] = body.get("ImoNumber"); changed = True
                    if not curr.get('callsign') and body.get("CallSign"):
                        curr['callsign'] = body.get("CallSign").strip(); changed = True
                    if not curr.get('dimensions') and body.get("Dimension"):
                        curr['dimensions'] = body.get("Dimension"); changed = True
                    if not curr.get('draught') and new_drgt != 0.0:
                        curr['draught'] = new_drgt; changed = True

                    if changed: updates += 1

        if updates > 0:
            save_cache(full_db_path, ship_cache)
            print(f"     Recorded {updates} improvements.")
        
        if i < chunks - 1:
            await asyncio.sleep(30)

    print(f"Harvest Complete. Total DB size: {len(ship_cache)}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Harvest Static Ship Data")
    parser.add_argument("--config", required=True, help="Path to main config")
    args = parser.parse_args()
    if not os.path.exists(args.config):
        raise FileNotFoundError(f"Config file not found at {args.config}")

    config = configparser.ConfigParser()
    config.read(args.config)
    s = SCRIPT_SECTION
    if not config.getboolean(s, 'enabled', fallback=False):
        sys.exit(0)

    try:
        harvest_params = {
            'workdir': config.get('common', 'workdir', fallback='.'),
            'url': config.get(s, 'url'),
            'api_key': config.get('shipping', 'api_key'),
            'duration': config.getint(s, 'listen_for_static_data'),
            'full_bbox': json.loads(config.get(s, 'harvest_bbox')),
            'chunks': config.getint(s, 'harvest_chunks'),
            'db_rel_path': config.get(s, 'static_database')
        }
        asyncio.run(run_chunked_harvest(**harvest_params))
    except Exception as e: print(f"Error: {e}")
