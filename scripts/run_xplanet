#!/usr/bin/env python3
import os
import sys
import glob
import time
import logging
import argparse
import subprocess
import configparser

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[logging.StreamHandler(sys.stdout)]
)
logger = logging.getLogger(__name__)


def main():
    parser = argparse.ArgumentParser(description="Run XPlanet to update World Map image")
    parser.add_argument("--config", required=True, help="Path to main config file")
    args = parser.parse_args()

    if not os.path.exists(args.config):
        logger.error(f"Config not found: {args.config}")
        sys.exit(1)

    config = configparser.ConfigParser()
    config.read(args.config)

    try:
        # 1. Extract Settings
        s = 'xplanet'
        workdir = config.get('common', 'workdir', fallback='.')
        data_dir = os.path.join(workdir, 'data')

        # XPlanet Parameters
        geometry = config.get(s, 'geometry', fallback='1920x1080')
        projection = config.get(s, 'projection', fallback='rectangular')
        longitude = config.get(s, 'longitude', fallback='175')
        x_conf = config.get(s, 'xplanet_conf', fallback='config/xplanet.conf')
        base_name = config.get(s, 'base_filename', fallback='worldmap.jpg')

        # Cleanup old map files
        # Matches files like data/*-worldmap.jpg
        search_pattern = os.path.join(data_dir, f"*-{base_name}")
        old_files = glob.glob(search_pattern)
        for old_file in old_files:
            try:
                os.remove(old_file)
                logger.info(f"Cleaned up old map: {old_file}")
            except Exception as e:
                logger.warning(f"Could not remove {old_file}: {e}")

        # 3. Generate new filename with Unix timestamp
        timestamp = int(time.time())
        output_path = os.path.join(data_dir, f"{timestamp}-{base_name}")

        cmd = [
            "xplanet",
            "-conf", x_conf,
            "-projection", projection,
            "-geometry", geometry,
            "-longitude", longitude,
            "-output", output_path,
            "-num_times", "1"
        ]

        logger.info(f"Executing XPlanet: {' '.join(cmd)}")
        subprocess.run(cmd, check=True)
        logger.info(f"Successfully generated {geometry} World map: {output_path}")

    except Exception as e:
        logger.error(f"XPlanet execution failed: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()