# --- Project Specific (Data & Config) ---
# Ignore all files in data/
data/*

# Ensure the live ship data cache is ignored even if the folder is negated
data/ship_cache.json

# Do NOT ignore these specific files
!data/ship_cache.json.example
!data/.gitkeep

# Ignore environment secrets
.env
.env.local

# --- Python ---
.venv/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/

# --- Build & Packaging ---
dist/
build/
*.egg-info/

# --- Docker ---
docker-compose.override.yml

# --- OS & IDEs ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# --- Ship Data / XPlanet Artifacts ---
# This catches any loose index or backup files in the root
*.idx
*.bak
*.tmp
